{
  "name": "todo",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "todo/src",
  "projectType": "application",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "vite",
        "cwd": "todo"
      },
      "dependsOn": ["shell:serve"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build",
        "cwd": "todo"
      }
    }
  }
}
